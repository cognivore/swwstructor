{
  "name": "swwstructor",
  "version": "0.1.0",
  "description": "Admin/preview web client for the swwstructor website constructor: type-safe content interfaces for an admin editor, and a live, responsive, sticky layout preview built on the stickywebwm TypeScript SDK.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test"
  },
  "keywords": [
    "swwstructor",
    "stickywebwm",
    "admin",
    "preview",
    "website-constructor"
  ],
  "license": "MIT",
  "author": "swwstructor",
  "dependencies": {
    "stickywebwm": "file:../../stickywebwm/ts"
  },
  "devDependencies": {
    "typescript": "^5.9",
    "@types/node": "^22"
  }
}
